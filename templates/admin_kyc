
<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Flinpay Admin — Revue KYC</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{--blue:#1A3CFF;--gold:#FFB400;--green:#00C48C;--ink:#0B0D17;--bg:#F5F6FB;--text:#12131C;--muted:#767A94;--danger:#FF4D4D;--border:#E7E9F3}
body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);padding:30px}
h1{font-family:'Space Grotesk',sans-serif;font-size:1.3rem;font-weight:800;margin-bottom:20px;display:flex;align-items:center;gap:10px}
.back{font-size:.82rem;color:var(--muted);text-decoration:none;display:inline-block;margin-bottom:16px}
.back:hover{color:var(--text)}
.card{background:white;border-radius:16px;border:1px solid var(--border);padding:20px 22px;margin-bottom:14px;box-shadow:0 1px 2px rgba(15,17,32,.04)}
.row{display:flex;justify-content:space-between;align-items:flex-start;gap:16px;flex-wrap:wrap}
.name{font-weight:700;font-size:1rem;margin-bottom:2px}
.email{font-size:.8rem;color:var(--muted);font-family:'JetBrains Mono',monospace}
.meta{font-size:.8rem;color:var(--muted);margin-top:8px;line-height:1.7}
.meta b{color:var(--text)}
.actions{display:flex;gap:8px;flex-shrink:0}
.btn{font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:.82rem;padding:9px 16px;border-radius:9px;border:none;cursor:pointer}
.btn-doc{background:var(--bg);color:var(--text);border:1.5px solid var(--border)}
.btn-approve{background:var(--green);color:white}
.btn-reject{background:var(--danger);color:white}
.empty{text-align:center;padding:60px 20px;color:var(--muted)}
</style>
</head>
<body>
<a class="back" href="/admin">← Retour à l'admin</a>
<h1>🪪 Demandes de vérification KYC <span style="color:var(--muted);font-weight:400;font-size:1rem">({{ pending|length }})</span></h1>

<div id="list">
  {% if not pending %}
    <div class="empty">Aucune demande en attente.</div>
  {% endif %}
  {% for u in pending %}
  <div class="card" data-user-id="{{ u.id }}">
    <div class="row">
      <div>
        <div class="name">{{ u.kyc_full_name or (u.firstname ~ ' ' ~ u.lastname) }}</div>
        <div class="email">{{ u.email }}</div>
        <div class="meta">
          <b>Pièce :</b> {{ u.kyc_id_type }} — {{ u.kyc_id_number }}<br>
          <b>Pays :</b> {{ u.country }} &nbsp; <b>Entreprise :</b> {{ u.company or '—' }}<br>
          <b>Soumis le :</b> {{ u.kyc_submitted_at }}
        </div>
      </div>
      <div class="actions">
        <button class="btn btn-doc" onclick="viewDoc('{{ u.id }}')">📄 Voir le document</button>
        <button class="btn btn-approve" onclick="reviewKyc('{{ u.id }}','approve')">✅ Approuver</button>
        <button class="btn btn-reject" onclick="reviewKyc('{{ u.id }}','reject')">❌ Rejeter</button>
      </div>
    </div>
  </div>
  {% endfor %}
</div>

<script>
async function viewDoc(userId){
  try{
    const r=await fetch('/api/admin/kyc/'+userId+'/document');
    const data=await r.json();
    if(data.ok){ window.open(data.url,'_blank'); }
    else{ alert(data.error||'Erreur'); }
  }catch(e){ alert('Erreur de connexion'); }
}
async function reviewKyc(userId, action){
  let reason=null;
  if(action==='reject'){
    reason=prompt('Raison du rejet :','Document illisible ou invalide');
    if(reason===null) return;
  }else{
    if(!confirm('Approuver cette demande ?')) return;
  }
  try{
    const r=await fetch('/api/admin/kyc/'+userId+'/'+action,{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: action==='reject' ? JSON.stringify({reason}) : undefined
    });
    const data=await r.json();
    if(data.ok){
      document.querySelector(`[data-user-id="${userId}"]`).remove();
    }else{
      alert(data.error||'Erreur lors de la mise à jour');
    }
  }catch(e){ alert('Erreur de connexion'); }
}
</script>
</body>
</html>
